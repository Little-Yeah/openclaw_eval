{
  "openclaw": {
    "trace_provider": {
      "base_url": "https://provider.example/v1",
      "api_format": "openai",
      "model": "provider/model-id"
    },
    "workers": 3,
    "trace_only": true
  },
  "inference": {
    "models": [
      {
        "name": "candidate-model",
        "api_format": "openai",
        "base_url": "https://your-openai-compatible-endpoint/v1",
        "api_key": "REPLACE_WITH_CANDIDATE_KEY",
        "model": "provider/model-id",
        "concurrency": 4,
        "max_tokens": 4096,
        "timeout": 180
      }
    ]
  },
  "evaluate": {
    "judge": {
      "name": "judge-model",
      "api_format": "openai",
      "base_url": "https://your-openai-compatible-endpoint/v1",
      "api_key": "REPLACE_WITH_JUDGE_KEY",
      "model": "provider/judge-model-id",
      "concurrency": 2,
      "max_tokens": 1024,
      "timeout": 120
    }
  }
}
